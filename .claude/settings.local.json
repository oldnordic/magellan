  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/query-schema-check.fish",
            "statusMessage": "🔍 Verifying database health before subagent starts..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/ci-check.fish",
            "statusMessage": "🔁 Checking GitHub CI status after push..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/query-symbol-check.fish",
            "statusMessage": "🔍 Verifying ground truth was queried before coding..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/verify-rust.fish",
            "statusMessage": "🦀 Verifying Rust code compiles and graph is updated..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/splice-cycles-check.fish",
            "statusMessage": "🔄 Checking for call graph cycles after refactoring..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/stub-check.fish",
            "statusMessage": "🚫 Checking for stub code (panic! in non-test)..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/wiring-check.fish",
            "statusMessage": "🔌 Verifying wiring (dead modules, parse-once, debug cleanup)..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/security-check.fish",
            "statusMessage": "🛡️ Checking for security issues in new code..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/deadlock-check.fish",
            "statusMessage": "🔒 Checking for potential deadlocks in call graph cycles..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/envoy-wrapper.fish $(dirname $(git rev-parse --git-common-dir))/.claude/hooks/ack-contract-check.fish",
            "statusMessage": "📝 Checking ACK contracts in peer messages..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/read-gate.fish",
            "statusMessage": "Checking if graph query would be better than file read..."
          },
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/token-counter-hook.fish",
            "statusMessage": "Tracking token usage for file read..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(dirname $(git rev-parse --git-common-dir))/.claude/hooks/logseq-session-hook.fish",
            "statusMessage": "📓 Logging session to Logseq..."
          }
        ]
      }
    ]
  },
  "skills": {
    "auto_load": [
      "code-intelligence-ecosystem",
      "code-intelligence-workflow",
      "graph-query",
      "wiring-check"
    ]
  }
}
